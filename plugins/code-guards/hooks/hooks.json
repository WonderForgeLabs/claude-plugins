{
  "description": "Protective hooks that block editing sensitive files and lint shell scripts",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/guard-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/shellcheck-guard.sh",
            "timeout": 15,
            "statusMessage": "Checking shell script..."
          }
        ]
      }
    ]
  }
}

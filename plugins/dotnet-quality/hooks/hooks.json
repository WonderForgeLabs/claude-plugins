{
  "description": "C# auto-formatting hook using dotnet format",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PLUGIN_ROOT/hooks/scripts/dotnet-format.sh",
            "timeout": 30,
            "statusMessage": "Formatting C#..."
          }
        ]
      }
    ]
  }
}
